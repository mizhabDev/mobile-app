{
  "expo": {
    "name": "EntePhoto",
    "slug": "entephoto-camera-selection",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "entephoto-camera-selection",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.entephoto.cameraselection",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "FlashLink needs access to your photos to share them with the connected device."
      }
    },
    "android": {
      "package": "com.entephoto.cameraselection",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.ACCESS_WIFI_STATE",
        "android.permission.CHANGE_NETWORK_STATE",
        "android.permission.CHANGE_WIFI_STATE",
        "android.permission.INTERNET",
        "android.permission.NEARBY_WIFI_DEVICES",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VIDEO"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "2e14310b-ad90-47bb-8060-8ad1caf4b8a7"
      }
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow FlashLink to access your camera to scan QR codes."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow FlashLink to share your photos with the connected device.",
          "savePhotosPermission": "Allow FlashLink to save photos.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ]
  }
}
